{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "bash build_railway.sh"
  },
  "deploy": {
    "startCommand": "sh -c 'php -S 0.0.0.0:${PORT} -t build/web'",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
